// Digital Door Lock - Mealy Machine (Simplified & Working)
module door_lock (
    input wire clk,
    input wire reset,
    input wire [3:0] code_input,
    input wire enter,
    output reg unlock,
    output reg error
);

    // States
    reg [2:0] state;
    
    // Correct code: 1,2,3,4
    parameter IDLE = 3'd0;
    parameter S1 = 3'd1;    // First digit correct
    parameter S2 = 3'd2;    // Second digit correct
    parameter S3 = 3'd3;    // Third digit correct
    
    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= IDLE;
            unlock <= 1'b0;
            error <= 1'b0;
        end
        else begin
            // Default values
            unlock <= 1'b0;
            error <= 1'b0;
            
            case (state)
                IDLE: begin
                    if (enter) begin
                        if (code_input == 4'd1) begin
                            state <= S1;
                        end
                        else begin
                            error <= 1'b1;
                            state <= IDLE;
                        end
                    end
                end
                
                S1: begin
                    if (enter) begin
                        if (code_input == 4'd2) begin
                            state <= S2;
                        end
                        else begin
                            error <= 1'b1;
                            state <= IDLE;
                        end
                    end
                end
                
                S2: begin
                    if (enter) begin
                        if (code_input == 4'd3) begin
                            state <= S3;
                        end
                        else begin
                            error <= 1'b1;
                            state <= IDLE;
                        end
                    end
                end
                
                S3: begin
                    if (enter) begin
                        if (code_input == 4'd4) begin
                            unlock <= 1'b1;  // Mealy output
                            state <= IDLE;
                        end
                        else begin
                            error <= 1'b1;
                            state <= IDLE;
                        end
                    end
                end
                
                default: state <= IDLE;
            endcase
        end
    end
    
endmodule
